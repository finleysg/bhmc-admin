{
	"permissions": {
		"allow": [
			"WebFetch",
			"Bash(curl:*)",
			"Bash(git commit:*)",
			"Bash(gh pr create:*)",
			"Bash(npx shadcn@latest add:*)",
			"Bash(pkill:*)",
			"Bash(tr:*)",
			"Bash(node:*)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "corepack enable pnpm 2>/dev/null || true"
					}
				]
			}
		]
	},
	"enabledMcpjsonServers": ["bhmc-db"]
}
