{
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
	},
	"permissions": {
		"allow": [
			"WebFetch",
			"Bash(curl:*)",
			"Bash(git commit:*)",
			"Bash(gh pr create:*)",
			"Bash(npx shadcn@latest add:*)",
			"Bash(pkill:*)",
			"Bash(tr:*)",
			"Bash(node:*)",
			"Bash(npx tsc:*)",
			"Bash(npx @contrast-checker/cli:*)",
			"WebSearch",
			"Bash(npx create-next-app@latest:*)",
			"Bash(npx:*)",
			"Bash(gh pr comment:*)",
			"mcp__bhmc-db__query",
			"mcp__bhmc-db__describe_table",
			"Bash(gh api:*)",
			"Bash(docker exec:*)",
			"Bash(docker-compose:*)",
			"Bash(sed:*)",
			"Bash(awk:*)",
			"Bash(/tmp/test-react-types.ts:*)",
			"Bash(python3:*)",
			"Bash(git -C:*)",
			"Bash(xargs:*)",
			"Skill(playwright-cli)",
			"Bash(playwright-cli:*)",
			"Bash(uv run python manage.py makemigrations courses)",
			"Bash(uv run python manage.py migrate courses)",
			"Bash(uv run python manage.py test)",
			"Bash(uv run python manage.py migrate)",
			"Bash(echo \"EXIT CODE: $?\")",
			"Bash(echo $TZ)",
			"Bash(/tmp/check-sse.js:*)",
			"Bash(/tmp/check-sse2.js:*)",
			"Bash(/tmp/check-open.js:*)",
			"Bash(DJANGO_ENV=local uv run python:*)",
			"Bash(uv run python:*)"
		]
	},
	"enabledMcpjsonServers": ["bhmc-db"],
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "corepack enable pnpm 2>/dev/null || true"
					}
				]
			}
		]
	}
}
