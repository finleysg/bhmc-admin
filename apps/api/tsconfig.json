{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"types": ["jest", "node"],
		"isolatedModules": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
